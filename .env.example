# Copy to .env.local (gitignored) and fill in.

# Sibling repo paths (default: ~/Documents/supernova/*)
E2E_BACKEND_PATH=
E2E_BACKOFFICE_PATH=
E2E_APP_PATH=

# URLs
BACKEND_URL=http://localhost:8000
BACKOFFICE_URL=http://localhost:3000

# Test database — will be created if missing
E2E_DATABASE_URL=postgresql://sabino@localhost:5432/saude_mental_e2e?schema=public

# Test users (seeded by `e2e seed`)
E2E_ADMIN_EMAIL=e2e-admin@supernovasw.com
E2E_ADMIN_PASSWORD=changeme
E2E_HR_EMAIL=e2e-hr@supernovasw.com
E2E_HR_PASSWORD=changeme
E2E_USER_EMAIL=e2e-user@supernovasw.com
E2E_USER_PASSWORD=changeme
