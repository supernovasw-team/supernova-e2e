{
  "name": "@supernovasw-team/supernova-e2e",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack E2E regression suite — Playwright (backoffice) + Maestro (app) + Prisma (DB). Single-command cross-stack scenarios.",
  "type": "module",
  "bin": {
    "e2e": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "e2e": "tsx src/cli/index.ts run",
    "doctor": "tsx src/cli/index.ts doctor",
    "report": "tsx src/cli/index.ts report",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "@playwright/test": "^1.48.0",
    "@prisma/client": "^5.22.0",
    "commander": "^12.1.0",
    "execa": "^9.5.0",
    "kleur": "^4.1.5",
    "ora": "^8.1.0",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "tesseract.js": "^5.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "eslint": "^9.12.0",
    "exceljs": "^4.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
